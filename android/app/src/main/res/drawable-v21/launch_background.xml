<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Deep dark saffron background -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#110806"
                android:centerColor="#1C110D"
                android:endColor="#2C1810"
                android:angle="135"
                android:type="linear"/>
        </shape>
    </item>

    <!-- Saffron circle behind JF -->
    <item>
        <bitmap
            android:gravity="center"
            android:src="@mipmap/ic_launcher"/>
    </item>

</layer-list>